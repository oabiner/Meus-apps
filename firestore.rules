rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == "abinerfelipe@gmail.com") ||
        ('email' in request.auth.token && request.auth.token.email == "server@deckserrinha.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'host'])
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == "abinerfelipe@gmail.com") ||
        ('email' in request.auth.token && request.auth.token.email == "server@deckserrinha.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'host', 'waiter', 'kitchen'])
      );
    }

    function isWaiterOrAdmin() {
      return isAuthenticated() && (
        ('email' in request.auth.token && request.auth.token.email == "abinerfelipe@gmail.com") ||
        ('email' in request.auth.token && request.auth.token.email == "server@deckserrinha.com") ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'host', 'waiter'])
      );
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'role', 'username']) &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.role in ['host', 'admin', 'waiter', 'kitchen'] &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50;
    }

    function isValidTable(data) {
      return data.keys().hasAll(['number', 'status']) &&
             data.number is number && data.number > 0 &&
             data.status in ['free', 'open', 'bill_requested'] &&
             (!('customer_name' in data) || (data.customer_name is string && data.customer_name.size() < 100)) &&
             (!('people_count' in data) || (data.people_count is number && data.people_count >= 0)) &&
             (!('opened_at' in data) || (data.opened_at is string && data.opened_at.size() < 50));
    }

    function isValidMenuItem(data) {
      return data.keys().hasAll(['name', 'price', 'type', 'category', 'active']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             (data.type == null || (data.type is string && data.type.size() < 50)) &&
             (data.category == null || (data.category is string && data.category.size() < 50)) &&
             data.active is number && data.active in [0, 1];
    }

    function isValidCategory(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidItemGroup(data) {
      return data.keys().hasAll(['name']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 50;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['table_id', 'menu_item_id', 'quantity', 'status', 'is_read', 'timestamp', 'item_name', 'item_price']) &&
             data.table_id is number && data.table_id > 0 &&
             data.menu_item_id is string && data.menu_item_id.size() > 0 && data.menu_item_id.size() < 100 &&
             data.quantity is number && data.quantity > 0 &&
             data.status in ['pending', 'delivered'] &&
             data.is_read is number && data.is_read in [0, 1] &&
             data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() < 50 &&
             data.item_name is string && data.item_name.size() > 0 && data.item_name.size() < 100 &&
             data.item_price is number && data.item_price >= 0 &&
             (!('observation' in data) || (data.observation is string && data.observation.size() < 500));
    }

    function isValidHistoryEvent(data) {
      return data.keys().hasAll(['user_id', 'username', 'action', 'details', 'is_read', 'timestamp']) &&
             data.user_id is string && data.user_id.size() > 0 && data.user_id.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.action is string && data.action.size() > 0 && data.action.size() < 50 &&
             data.details is string && data.details.size() > 0 && data.details.size() < 500 &&
             data.is_read is number && data.is_read in [0, 1] &&
             data.timestamp is string && data.timestamp.size() > 0 && data.timestamp.size() < 50 &&
             (!('order_id' in data) || (data.order_id is string && data.order_id.size() < 100));
    }

    function isValidSetting(data) {
      return data.keys().hasAll(['value']) &&
             data.value is string && data.value.size() < 1000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidUser(request.resource.data);
      allow update: if isAdmin() && isValidUser(request.resource.data);
      allow delete: if isAdmin();
    }

    match /tables/{tableId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidTable(request.resource.data);
      allow update: if isWaiterOrAdmin() && isValidTable(request.resource.data);
      allow delete: if isAdmin();
    }

    match /menu_items/{menuItemId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidMenuItem(request.resource.data);
      allow update: if isAdmin() && isValidMenuItem(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data);
      allow delete: if isAdmin();
    }

    match /item_groups/{groupId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidItemGroup(request.resource.data);
      allow update: if isAdmin() && isValidItemGroup(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isStaff();
      allow create: if isWaiterOrAdmin() && isValidOrder(request.resource.data);
      allow update: if isStaff() && isValidOrder(request.resource.data);
      allow delete: if isWaiterOrAdmin();
    }

    match /history/{historyId} {
      allow read: if isStaff();
      allow create: if isStaff() && isValidHistoryEvent(request.resource.data);
      allow update: if isStaff() && isValidHistoryEvent(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isStaff();
      allow create: if isAdmin() && isValidSetting(request.resource.data);
      allow update: if isAdmin() && isValidSetting(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
